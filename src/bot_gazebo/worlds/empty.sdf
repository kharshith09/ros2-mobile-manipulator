  <!-- Small round table NE  (purple accent) -->
  <model name="side_table">
    <static>true</static><pose>5.5 4.5 0.45 0 0 0</pose>
    <link name="link">
      <collision name="col">
        <geometry><cylinder><radius>0.4</radius><length>0.9</length></cylinder></geometry>
      </collision>
      <visual name="vis">
        <geometry><cylinder><radius>0.4</radius><length>0.9</length></cylinder></geometry>
        <material>
