          <specular>0.2 0.2 0.5 1</specular>
        </material>
      </visual>
    </link>
  </model>

  <!-- Worktop counter  (light grey) -->
  <model name="counter">
    <static>true</static><pose>6.6 2.5 0.5 0 0 0</pose>
    <link name="link">
      <collision name="col"><geometry><box><size>0.6 2.5 1.0</size></box></geometry></collision>
      <visual name="vis">
        <geometry><box><size>0.6 2.5 1.0</size></box></geometry>
        <material>
