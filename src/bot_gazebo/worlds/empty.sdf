    </link>
  </model>

  <!-- Bookshelf  (dark walnut) -->
  <model name="bookshelf">
    <static>true</static><pose>6.6 -3.5 1.0 0 0 0</pose>
    <link name="link">
      <collision name="col"><geometry><box><size>0.3 2.5 2.0</size></box></geometry></collision>
      <visual name="vis">
        <geometry><box><size>0.3 2.5 2.0</size></box></geometry>
        <material>
          <ambient>0.28 0.16 0.08 1</ambient>
          <diffuse>0.28 0.16 0.08 1</diffuse>
          <specular>0.2 0.15 0.08 1</specular>
        </material>
      </visual>
    </link>
  </model>

  <!-- Coloured crate stack ── red, yellow, blue -->
  <model name="crate_red">
    <static>true</static><pose>3.5 -4.0 0.25 0 0 0</pose>
    <link name="link">
      <collision name="col"><geometry><box><size>0.5 0.5 0.5</size></box></geometry></collision>
      <visual name="vis">
        <geometry><box><size>0.5 0.5 0.5</size></box></geometry>
        <material>
          <ambient>0.85 0.15 0.15 1</ambient>
          <diffuse>0.85 0.15 0.15 1</diffuse>
          <specular>0.3 0.1 0.1 1</specular>
        </material>
