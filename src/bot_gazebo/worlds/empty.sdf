  <model name="crate_yellow">
    <static>true</static><pose>4.2 -4.0 0.25 0 0 0</pose>
    <link name="link">
      <collision name="col"><geometry><box><size>0.5 0.5 0.5</size></box></geometry></collision>
      <visual name="vis">
        <geometry><box><size>0.5 0.5 0.5</size></box></geometry>
        <material>
          <ambient>0.95 0.82 0.10 1</ambient>
          <diffuse>0.95 0.82 0.10 1</diffuse>
