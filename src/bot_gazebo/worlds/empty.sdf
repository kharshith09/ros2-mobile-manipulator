  <model name="crate_blue">
    <static>true</static><pose>3.85 -4.0 0.75 0 0 0</pose>
    <link name="link">
      <collision name="col"><geometry><box><size>0.5 0.5 0.5</size></box></geometry></collision>
      <visual name="vis">
