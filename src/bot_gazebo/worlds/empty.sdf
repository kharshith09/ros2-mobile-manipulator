  </model>

  <!-- Round pillar  (terracotta accent) -->
  <model name="pillar">
    <static>true</static><pose>0.5 4.5 1.5 0 0 0</pose>
    <link name="link">
      <collision name="col">
        <geometry><cylinder><radius>0.22</radius><length>3.0</length></cylinder></geometry>
      </collision>
      <visual name="vis">
        <geometry><cylinder><radius>0.22</radius><length>3.0</length></cylinder></geometry>
        <material>
          <ambient>0.78 0.38 0.22 1</ambient>
          <diffuse>0.78 0.38 0.22 1</diffuse>
          <specular>0.2 0.12 0.08 1</specular>
