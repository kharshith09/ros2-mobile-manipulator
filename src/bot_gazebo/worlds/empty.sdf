        </material>
      </visual>
    </link>
  </model>

  <!-- Lamp on side table  (orange glow) -->
  <!-- lamp shade kept as visual-only, no point light -->
  <model name="lamp_shade">
    <static>true</static><pose>5.5 4.5 1.15 0 0 0</pose>
    <link name="link">
      <visual name="vis">
        <geometry><cylinder><radius>0.2</radius><length>0.35</length></cylinder></geometry>
        <material>
          <ambient>1.0 0.60 0.15 1</ambient>
          <diffuse>1.0 0.60 0.15 1</diffuse>
          <emissive>0.8 0.40 0.05 1</emissive>
          <specular>0.2 0.2 0.1 1</specular>
        </material>
      </visual>
    </link>
  </model>

</world>
</sdf>
